# ============================================================
# ERP Food Bites - Backend Configuration
# ============================================================
# Copy this file to .env and configure for your environment.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# SERVER
# ------------------------------------------------------------
# Port where the NestJS server will listen
PORT=5000

# Environment: development | production | test
NODE_ENV=development

# ------------------------------------------------------------
# DATABASE (PostgreSQL)
# ------------------------------------------------------------
# Connection string format: postgresql://user:password@host:port/database
# For local PostgreSQL installation:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_food_bites

# ------------------------------------------------------------
# JWT (JSON Web Token)
# ------------------------------------------------------------
# Secret key for signing JWT tokens
# IMPORTANT: Generate a strong random string for production
# Example: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-strong-random-secret

# Token expiration time (default: 1h)
# JWT_EXPIRES_IN=1h

# ------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ------------------------------------------------------------
# Allowed origin for cross-origin requests
# For Flutter web app:
CORS_ORIGIN=http://localhost:3000

# For local file:// protocol (Flutter desktop):
# CORS_ORIGIN=*
